# Binance API (read-only + futures)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=futures_bot

# Signal Settings
CONFIDENCE_THRESHOLD=0.70
ATR_TP1_MULT=1.0
ATR_TP2_MULT=2.0
ATR_TP3_MULT=3.0
ATR_SL_MULT=1.5

# Retraining
RETRAIN_DAY=monday
RETRAIN_HOUR=3
LOOKBACK_MONTHS=12
FORWARD_WINDOW_CANDLES=50

# Web Dashboard
WEB_HOST=0.0.0.0
WEB_PORT=8000
